@model BaithuchanhORM.Models.Book

@{
    ViewData["Title"] = "Create";
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <h1 class="h3 mb-0">Thêm sách</h1>
    <a class="btn btn-secondary" asp-action="Index">Quay lại</a>
</div>

<div class="card">
    <div class="card-body">
        <form asp-action="Create" method="post" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <partial name="_BookForm" model="Model" />

            <div class="mt-3">
                <label class="form-label">Ảnh sách (JPG/PNG, có thể chọn nhiều ảnh)</label>
                <input type="file" name="images" class="form-control" accept=".jpg,.jpeg,.png,image/jpeg,image/png" multiple />
                @if (ViewData.ModelState["images"]?.Errors.Count > 0)
                {
                    foreach (var error in ViewData.ModelState["images"]!.Errors)
                    {
                        <div class="text-danger">@error.ErrorMessage</div>
                    }
                }
            </div>

            <div class="mt-3 d-flex gap-2">
                <button type="submit" class="btn btn-primary">Lưu</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Hủy</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
