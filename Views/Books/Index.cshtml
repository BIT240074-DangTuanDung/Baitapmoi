@model IEnumerable<BaithuchanhORM.Models.Book>

@{
    ViewData["Title"] = "Quản lý sách";
}

<div class="container py-4">
    <div class="d-flex align-items-center justify-content-between mb-5">
        <h1 class="display-5 fw-bold">📖 Quản lý sách</h1>
        <a class="btn btn-primary btn-lg shadow-sm" asp-action="Create">
            ➕ Thêm sách mới
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-10">
            <div class="display-1 text-muted mb-4">📚</div>
            <h3 class="text-muted">Chưa có sách nào</h3>
            <p class="text-muted mb-4">Hãy thêm sách đầu tiên của bạn!</p>
            <a class="btn btn-primary btn-lg" asp-action="Create">➕ Thêm sách</a>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-5">
            @foreach (var item in Model)
            {
                var firstImage = item.Images.FirstOrDefault();
                <div class="col">
                    <div class="card h-100 shadow-sm hover-shadow transition-all">
                        <div class="position-relative" style="height: 200px; background-color: #f8f9fa; overflow: hidden;">
                            @if (firstImage is not null)
                            {
                                <img src="@firstImage.FilePath" alt="@item.Title" class="w-100 h-100 object-fit-cover" />
                            }
                            else
                            {
                                <div class="d-flex align-items-center justify-content-center h-100 text-muted">
                                    <span class="display-1">📕</span>
                                </div>
                            }
                            <span class="position-absolute top-3 end-3 badge bg-primary shadow-sm">@item.Stock cuốn</span>
                        </div>
                        <div class="card-body">
                            <h5 class="card-title fw-bold mb-2 text-truncate" title="@item.Title">@item.Title</h5>
                            <p class="card-text text-muted mb-1">
                                <small>Tác giả: @item.Author</small>
                            </p>
                            <p class="card-text text-primary fw-bold fs-5 mb-3">
                                @item.Price.ToString("N0") đ
                            </p>
                            <div class="d-flex gap-2">
                                <a class="btn btn-outline-primary btn-sm flex-grow-1" asp-action="Details" asp-route-id="@item.Id">
                                    🔍 Xem
                                </a>
                                <a class="btn btn-outline-secondary btn-sm" asp-action="Edit" asp-route-id="@item.Id">
                                    ✏️
                                </a>
                                <a class="btn btn-outline-danger btn-sm" asp-action="Delete" asp-route-id="@item.Id">
                                    🗑️
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .hover-shadow:hover {
        transform: translateY(-4px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
    }
    .transition-all {
        transition: all 0.3s ease;
    }
</style>
