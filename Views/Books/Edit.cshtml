@model BaithuchanhORM.Models.Book

@{
    ViewData["Title"] = "Edit";
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <div>
        <h1 class="h3 mb-0">Sửa sách</h1>
        <div class="text-muted">#@Model.Id</div>
    </div>
    <a class="btn btn-secondary" asp-action="Index">Quay lại</a>
</div>

@if (Model.Images.Count > 0)
{
    <div class="card mb-3">
        <div class="card-body">
            <label class="form-label">Ảnh hiện tại</label>
            <div class="d-flex flex-wrap gap-3">
                @foreach (var image in Model.Images)
                {
                    <div class="text-center">
                        <img src="@image.FilePath" alt="@image.FileName" class="img-thumbnail" style="width: 96px; height: 96px; object-fit: cover;" />
                        <form asp-action="DeleteImage" method="post" class="mt-1">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@image.Id" />
                            <input type="hidden" name="bookId" value="@Model.Id" />
                            <button type="submit" class="btn btn-sm btn-outline-danger">Xóa ảnh</button>
                        </form>
                    </div>
                }
            </div>
        </div>
    </div>
}

<div class="card">
    <div class="card-body">
        <form asp-action="Edit" method="post" enctype="multipart/form-data">
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <partial name="_BookForm" model="Model" />

            <div class="mt-3">
                <label class="form-label">Thêm ảnh mới (JPG/PNG, có thể chọn nhiều ảnh)</label>
                <input type="file" name="images" class="form-control" accept=".jpg,.jpeg,.png,image/jpeg,image/png" multiple />
                @if (ViewData.ModelState["images"]?.Errors.Count > 0)
                {
                    foreach (var error in ViewData.ModelState["images"]!.Errors)
                    {
                        <div class="text-danger">@error.ErrorMessage</div>
                    }
                }
            </div>

            <div class="mt-3 d-flex gap-2">
                <button type="submit" class="btn btn-primary">Lưu</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Hủy</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
