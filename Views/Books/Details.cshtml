@model BaithuchanhORM.Models.Book

@{
    ViewData["Title"] = "Details";
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <div>
        <h1 class="h3 mb-0">Chi tiết sách</h1>
        <div class="text-muted">#@Model.Id</div>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-outline-primary" asp-action="Edit" asp-route-id="@Model.Id">Sửa</a>
        <a class="btn btn-outline-danger" asp-action="Delete" asp-route-id="@Model.Id">Xóa</a>
        <a class="btn btn-secondary" asp-action="Index">Quay lại</a>
    </div>
</div>

<div class="card">
    <div class="card-body">
        @if (Model.Images.Count > 0)
        {
            <div class="mb-4 d-flex flex-wrap gap-2">
                @foreach (var image in Model.Images)
                {
                    <img src="@image.FilePath" alt="@image.FileName" class="img-thumbnail" style="width: 120px; height: 120px; object-fit: cover;" />
                }
            </div>
        }

        <dl class="row mb-0">
            <dt class="col-sm-3">Tiêu đề</dt>
            <dd class="col-sm-9">@Model.Title</dd>

            <dt class="col-sm-3">Tác giả</dt>
            <dd class="col-sm-9">@Model.Author</dd>

            <dt class="col-sm-3">Nhà xuất bản</dt>
            <dd class="col-sm-9">@(!string.IsNullOrWhiteSpace(Model.Publisher) ? Model.Publisher : "-")</dd>

            <dt class="col-sm-3">Giá</dt>
            <dd class="col-sm-9">@Model.Price.ToString("N0") đ</dd>

            <dt class="col-sm-3">Tồn kho</dt>
            <dd class="col-sm-9">@Model.Stock</dd>

            <dt class="col-sm-3">Ngày xuất bản</dt>
            <dd class="col-sm-9">@Model.PublishedDate?.ToString("yyyy-MM-dd")</dd>
        </dl>
    </div>
</div>
